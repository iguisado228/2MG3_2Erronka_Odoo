<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_erronka_langile_tree" model="ir.ui.view">
        <field name="name">erronka.langile.tree</field>
        <field name="model">erronka.langile</field>
        <field name="arch" type="xml">
            <tree>
                <header>
                    <!-- Kanpoko BBDD-tik Odoo-ra sinkronizazioa abiarazteko botoia -->
                    <button name="sync_langileak_desde_api" type="object" string="Cargar BBDD Externa" class="oe_highlight"/>
                </header>
                <field name="name"/>
                <field name="nan"/>
                <field name="erabiltzaile_izena"/>
                <field name="langile_kodea"/>
                <field name="lanpostu_id"/>
                <field name="sync_enabled"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_erronka_langile_form" model="ir.ui.view">
        <field name="name">erronka.langile.form</field>
        <field name="model">erronka.langile</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Kanpoko BBDD-tik Odoo-ra sinkronizazioa abiarazteko botoia -->
                    <button name="sync_langileak_desde_api" type="object" string="Cargar BBDD Externa" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="izena"/>
                            <field name="abizena"/>
                            <field name="nan"/>
                            <field name="erabiltzaile_izena"/>
                        </group>
                        <group>
                            <field name="langile_kodea"/>
                            <field name="lanpostu_id"/>
                            <field name="helbidea"/>
                            <field name="sync_enabled"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group groups="base.group_system">
                        <group attrs="{'invisible': [('id', '!=', False)]}">
                            <field name="password_new" password="True"/>
                            <field name="password_new_confirm" password="True"/>
                        </group>
                        <button name="action_open_password_wizard" type="object" string="Resetear contraseña" class="oe_highlight" attrs="{'invisible': [('id', '=', False)]}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_erronka_langile_password_wizard_form" model="ir.ui.view">
        <field name="name">erronka.langile.password.wizard.form</field>
        <field name="model">erronka.langile.password.wizard</field>
        <field name="arch" type="xml">
            <form string="Actualizar contraseña">
                <group>
                    <field name="langile_id" readonly="1"/>
                    <field name="password_new" password="True"/>
                    <field name="password_new_confirm" password="True"/>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Guardar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_erronka_langile_password_wizard" model="ir.actions.act_window">
        <field name="name">Actualizar contraseña</field>
        <field name="res_model">erronka.langile.password.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_erronka_langile_password_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{}</field>
    </record>

    <record id="view_erronka_langile_kanban" model="ir.ui.view">
        <field name="name">erronka.langile.kanban</field>
        <field name="model">erronka.langile</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="name"/>
                <field name="nan"/>
                <field name="erabiltzaile_izena"/>
                <field name="lanpostu_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_card">
                            <div class="o_kanban_details">
                                <strong>
                                    <field name="name"/>
                                </strong>
                                <div>
                                    <span>NAN: </span><field name="nan"/>
                                </div>
                                <div>
                                    <span>Usuario: </span><field name="erabiltzaile_izena"/>
                                </div>
                                <div>
                                    <span>Lanpostua: </span><field name="lanpostu_id"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_erronka_langile_search" model="ir.ui.view">
        <field name="name">erronka.langile.search</field>
        <field name="model">erronka.langile</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="nan"/>
                <field name="erabiltzaile_izena"/>
                <field name="lanpostu_id"/>
                <filter string="Activos" name="active" domain="[('active','=',True)]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Lanpostua" name="group_lanpostu" context="{'group_by':'lanpostu_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_erronka_langile" model="ir.actions.act_window">
        <field name="name">Langileak</field>
        <field name="res_model">erronka.langile</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_erronka_langile_search"/>
        <field name="context">{}</field>
    </record>

    <!-- Ekintza honek gure vista zehatzak erabiltzea behartzen du (tree/kanban/form) -->
    <record id="action_erronka_langile_view_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_erronka_langile_tree"/>
        <field name="act_window_id" ref="action_erronka_langile"/>
    </record>

    <record id="action_erronka_langile_view_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_erronka_langile_kanban"/>
        <field name="act_window_id" ref="action_erronka_langile"/>
    </record>

    <record id="action_erronka_langile_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_erronka_langile_form"/>
        <field name="act_window_id" ref="action_erronka_langile"/>
    </record>

    <!-- "Acción" menutik (lista/kanban/form) sinkronizazioa exekutatzeko server action-a -->
    <record id="action_sync_langileak_desde_mysql" model="ir.actions.server">
        <field name="name">Cargar BBDD Externa</field>
        <field name="model_id" ref="model_erronka_langile"/>
        <field name="binding_model_id" ref="model_erronka_langile"/>
        <field name="binding_view_types">list,kanban,form</field>
        <field name="state">code</field>
        <field name="code">action = env['erronka.langile'].sync_langileak_desde_api()</field>
    </record>
</odoo>
