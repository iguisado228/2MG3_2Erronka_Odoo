<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Menu bakoitzean klik egitean datuak eguneratzeko server action-ak -->
    <record id="action_erronka_estatistikak_open_dashboard" model="ir.actions.server">
        <field name="name">Estatistikak - Dashboard (eguneratu)</field>
        <field name="model_id" ref="model_erronka_estatistika_salmenta"/>
        <field name="state">code</field>
        <field name="code">
env["erronka.estatistika.salmenta"]._eguneratu_datuak()
env["erronka.estatistika.produktua"]._eguneratu_datuak()
env["erronka.estatistika.osagaia_stock"]._eguneratu_datuak()
env.cr.execute("CREATE TABLE IF NOT EXISTS board_board (id integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY)")
dashboard_view_id = env.ref("Erronka_estatistikak.view_erronka_estatistikak_dashboard_board").id
Custom = env["ir.ui.view.custom"].sudo()
custom_view = Custom.search([("user_id", "=", env.uid), ("ref_id", "=", dashboard_view_id)], limit=1)
base_view = env["ir.ui.view"].sudo().browse(dashboard_view_id)
if not custom_view:
    custom_view = Custom.create({"user_id": env.uid, "ref_id": dashboard_view_id, "arch": base_view.arch_db})
else:
    custom_view.write({"arch": base_view.arch_db})
action = env.ref("Erronka_estatistikak.action_erronka_estatistikak_dashboard_board").read()[0]
action["context"] = dict(env.context)
        </field>
    </record>

    <record id="action_erronka_estatistikak_open_salmentak" model="ir.actions.server">
        <field name="name">Estatistikak - Salmentak (eguneratu)</field>
        <field name="model_id" ref="model_erronka_estatistika_salmenta"/>
        <field name="state">code</field>
        <field name="code">
env["erronka.estatistika.salmenta"]._eguneratu_datuak()
action = env.ref("Erronka_estatistikak.action_erronka_estatistika_salmenta").read()[0]
action["hideCustomGroupBy"] = True
action["context"] = dict(env.context, search_default_fecha_dia=1)
        </field>
    </record>

    <record id="action_erronka_estatistikak_open_produktuak" model="ir.actions.server">
        <field name="name">Estatistikak - Produktuak (eguneratu)</field>
        <field name="model_id" ref="model_erronka_estatistika_produktua"/>
        <field name="state">code</field>
        <field name="code">
env["erronka.estatistika.produktua"]._eguneratu_datuak()
action = env.ref("Erronka_estatistikak.action_erronka_estatistika_produktua").read()[0]
action["context"] = dict(env.context)
        </field>
    </record>

    <record id="action_erronka_estatistikak_open_stocka" model="ir.actions.server">
        <field name="name">Estatistikak - Stocka (eguneratu)</field>
        <field name="model_id" ref="model_erronka_estatistika_osagaia_stock"/>
        <field name="state">code</field>
        <field name="code">
env["erronka.estatistika.osagaia_stock"]._eguneratu_datuak()
action = env.ref("Erronka_estatistikak.action_erronka_estatistika_osagaia_stock").read()[0]
action["context"] = dict(env.context)
        </field>
    </record>

    <!-- Dashboard-eko grafiko txikiak egiteko ekintzak -->
    <record id="action_erronka_estatistika_salmenta_graph_only" model="ir.actions.act_window">
        <field name="name">Salmentak</field>
        <field name="res_model">erronka.estatistika.salmenta</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_erronka_estatistika_salmenta_graph"/>
    </record>

    <record id="action_erronka_estatistika_produktua_graph_only" model="ir.actions.act_window">
        <field name="name">Produktuak</field>
        <field name="res_model">erronka.estatistika.produktua</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_erronka_estatistika_produktua_graph"/>
    </record>

    <record id="action_erronka_estatistika_osagaia_stock_graph_only" model="ir.actions.act_window">
        <field name="name">Stocka</field>
        <field name="res_model">erronka.estatistika.osagaia_stock</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_erronka_estatistika_osagaia_stock_graph"/>
    </record>

    <!-- Dashboard grafikoa: laburpena grafiko bidez -->
    <record id="view_erronka_estatistikak_dashboard_board" model="ir.ui.view">
        <field name="name">erronka.estatistikak.dashboard.board</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Estatistikak - Dashboard" class="erronka_estatistikak_dashboard">
                <board style="1-1-1">
                    <column>
                        <action name="%(action_erronka_estatistika_salmenta_graph_only)d" string="Salmentak" view_mode="graph" domain="[]" context="{'search_default_fecha_dia': 1}"/>
                    </column>
                    <column>
                        <action name="%(action_erronka_estatistika_produktua_graph_only)d" string="Produktuak" view_mode="graph" domain="[]" context="{}"/>
                    </column>
                    <column>
                        <action name="%(action_erronka_estatistika_osagaia_stock_graph_only)d" string="Stocka" view_mode="graph" domain="[]" context="{}"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <template id="erronka_estatistikak_hide_board_layout" inherit_id="web.assets_backend_legacy_lazy">
        <xpath expr="." position="inside">
            <style>
                .o-dashboard-header,
                .o_dashboard_header,
                .o_dashboard_header_btns,
                .o_dashboard_header_buttons,
                .o_board_controller .o_dashboard_header,
                .o_control_panel .o_dashboard_header,
                .o_board_controller .o-dashboard-header,
                .o_control_panel .o-dashboard-header {
                    display: none !important;
                }
            </style>
        </xpath>
    </template>

    <record id="action_erronka_estatistikak_dashboard_board" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_erronka_estatistikak_dashboard_board"/>
        <field name="target">current</field>
    </record>

    <!-- Dashboard: laburpen orokorra -->
    <record id="view_erronka_estatistika_dashboard_form" model="ir.ui.view">
        <field name="name">erronka.estatistika.dashboard.form</field>
        <field name="model">erronka.estatistika.dashboard</field>
        <field name="arch" type="xml">
            <form string="Estatistikak - Dashboard">
                <header>
                    <button type="action" name="%(action_erronka_estatistikak_open_dashboard)d" string="Birkargatu" class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <group string="Salmentak (hist.)">
                            <field name="salmenta_totala"/>
                            <field name="erreserba_kopurua"/>
                            <field name="ticket_batezbestekoa"/>
                            <button type="action" name="%(action_erronka_estatistikak_open_salmentak)d" string="Ikusi salmentak" class="btn-secondary"/>
                        </group>
                        <group string="Produktuak">
                            <field name="top_produktua"/>
                            <field name="top_kantitatea"/>
                            <button type="action" name="%(action_erronka_estatistikak_open_produktuak)d" string="Ikusi produktuak" class="btn-secondary"/>
                        </group>
                    </group>
                    <group string="Stocka">
                        <field name="stock_gutxi_kopurua"/>
                        <button type="action" name="%(action_erronka_estatistikak_open_stocka)d" string="Ikusi stocka" class="btn-secondary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_erronka_estatistika_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">erronka.estatistika.dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_erronka_estatistika_dashboard_form"/>
        <field name="target">current</field>
    </record>

    <!-- Salmentak: zerrenda + grafikoak -->
    <record id="view_erronka_estatistika_salmenta_tree" model="ir.ui.view">
        <field name="name">erronka.estatistika.salmenta.tree</field>
        <field name="model">erronka.estatistika.salmenta</field>
        <field name="arch" type="xml">
            <tree>
                <header>
                    <button name="action_eguneratu" type="object" string="Eguneratu datuak" class="oe_highlight"/>
                </header>
                <field name="eguna"/>
                <field name="salmenta_totala"/>
                <field name="erreserba_kopurua"/>
                <field name="ticket_batezbestekoa"/>
            </tree>
        </field>
    </record>

    <record id="view_erronka_estatistika_salmenta_graph" model="ir.ui.view">
        <field name="name">erronka.estatistika.salmenta.graph</field>
        <field name="model">erronka.estatistika.salmenta</field>
        <field name="arch" type="xml">
            <graph string="Salmentak" type="line">
                <field name="ticket_batezbestekoa" type="measure" operator="avg"/>
            </graph>
        </field>
    </record>

    <record id="view_erronka_estatistika_salmenta_search" model="ir.ui.view">
        <field name="name">erronka.estatistika.salmenta.search</field>
        <field name="model">erronka.estatistika.salmenta</field>
        <field name="arch" type="xml">
            <search string="Salmentak">
                <group expand="0" string="Fecha">
                    <filter string="Día" name="fecha_dia" context="{'group_by':'eguna_key_day'}"/>
                    <filter string="Mes" name="fecha_mes" context="{'group_by':'eguna_key_month'}"/>
                    <filter string="Trimestre" name="fecha_trimestre" context="{'group_by':'eguna_key_quarter'}"/>
                    <filter string="Año" name="fecha_ano" context="{'group_by':'eguna_key_year'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_erronka_estatistika_salmenta" model="ir.actions.act_window">
        <field name="name">Salmentak</field>
        <field name="res_model">erronka.estatistika.salmenta</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_erronka_estatistika_salmenta_graph"/>
        <field name="search_view_id" ref="view_erronka_estatistika_salmenta_search"/>
    </record>

    <!-- Produktuak: zerrenda + grafikoak -->
    <record id="view_erronka_estatistika_produktua_tree" model="ir.ui.view">
        <field name="name">erronka.estatistika.produktua.tree</field>
        <field name="model">erronka.estatistika.produktua</field>
        <field name="arch" type="xml">
            <tree>
                <header>
                    <button name="action_eguneratu" type="object" string="Eguneratu datuak" class="oe_highlight"/>
                </header>
                <field name="eguna"/>
                <field name="produktua_izena"/>
                <field name="ordainduta"/>
                <field name="kantitatea"/>
                <field name="diru_totala"/>
            </tree>
        </field>
    </record>

    <record id="view_erronka_estatistika_produktua_graph" model="ir.ui.view">
        <field name="name">erronka.estatistika.produktua.graph</field>
        <field name="model">erronka.estatistika.produktua</field>
        <field name="arch" type="xml">
            <graph string="Produktuak" type="bar">
                <field name="kantitatea" type="measure"/>
                <field name="diru_totala" type="measure"/>
                <field name="produktua_izena" type="row"/>
                <field name="eguna" type="col"/>
            </graph>
        </field>
    </record>

    <record id="action_erronka_estatistika_produktua" model="ir.actions.act_window">
        <field name="name">Produktuak</field>
        <field name="res_model">erronka.estatistika.produktua</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_erronka_estatistika_produktua_graph"/>
    </record>

    <!-- Stocka: zerrenda + grafikoak -->
    <record id="view_erronka_estatistika_osagaia_stock_tree" model="ir.ui.view">
        <field name="name">erronka.estatistika.osagaia_stock.tree</field>
        <field name="model">erronka.estatistika.osagaia_stock</field>
        <field name="arch" type="xml">
            <tree>
                <header>
                    <button name="action_eguneratu" type="object" string="Eguneratu datuak" class="oe_highlight"/>
                </header>
                <field name="osagaia_izena"/>
                <field name="stock"/>
                <field name="prezioa"/>
                <field name="azken_eguneraketa"/>
            </tree>
        </field>
    </record>

    <record id="view_erronka_estatistika_osagaia_stock_graph" model="ir.ui.view">
        <field name="name">erronka.estatistika.osagaia_stock.graph</field>
        <field name="model">erronka.estatistika.osagaia_stock</field>
        <field name="arch" type="xml">
            <graph string="Stocka" type="bar">
                <field name="stock" type="measure"/>
                <field name="osagaia_izena" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_erronka_estatistika_osagaia_stock" model="ir.actions.act_window">
        <field name="name">Stocka</field>
        <field name="res_model">erronka.estatistika.osagaia_stock</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_erronka_estatistika_osagaia_stock_graph"/>
    </record>

    <!-- Wizard: dena batera eguneratzeko popup-a -->
    <record id="view_erronka_estatistika_eguneratu_wizard_form" model="ir.ui.view">
        <field name="name">erronka.estatistika.eguneratu.wizard.form</field>
        <field name="model">erronka.estatistika.eguneratu.wizard</field>
        <field name="arch" type="xml">
            <form string="Estatistikak eguneratu">
                <group>
                    <div class="o_form_label">Egin klik 'Eguneratu' botoian API-tik datuak berriz kalkulatzeko.</div>
                </group>
                <footer>
                    <button name="action_eguneratu_dena" type="object" string="Eguneratu" class="btn-primary"/>
                    <button string="Utzi" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_erronka_estatistika_eguneratu_wizard" model="ir.actions.act_window">
        <field name="name">Estatistikak eguneratu</field>
        <field name="res_model">erronka.estatistika.eguneratu.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_erronka_estatistika_eguneratu_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
