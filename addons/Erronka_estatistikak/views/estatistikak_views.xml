<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Server action-ak = menuan klik egitean exekutatzen den “python txiki” bat.-->
    <record id="action_erronka_estatistikak_open_dashboard" model="ir.actions.server">
        <field name="name">Estatistikak - Dashboard (eguneratu)</field>
        <field name="model_id" ref="model_erronka_estatistika_salmenta" />
        <field name="state">code</field>
        <field name="code">
env["erronka.estatistika.salmenta"]._eguneratu_datuak()
env["erronka.estatistika.produktua"]._eguneratu_datuak()
env["erronka.estatistika.osagaia_stock"]._eguneratu_datuak()
## Board dashboard-a erabiltzeko behar den taula (batzuetan ez dago sortuta eta errorra ematen du)
env.cr.execute("CREATE TABLE IF NOT EXISTS board_board (id integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY)")
dashboard_view_id = env.ref("Erronka_estatistikak.view_erronka_estatistikak_dashboard_board").id
## Dashboard-a erabiltzaile bakoitzak pertsonaliza dezake; hemen “custom view” berritzen dugu, beti azken arch-arekin
Custom = env["ir.ui.view.custom"].sudo()
custom_view = Custom.search([("user_id", "=", env.uid), ("ref_id", "=", dashboard_view_id)], limit=1)
base_view = env["ir.ui.view"].sudo().browse(dashboard_view_id)
if not custom_view:
    custom_view = Custom.create({"user_id": env.uid, "ref_id": dashboard_view_id, "arch": base_view.arch_db})
else:
    custom_view.write({"arch": base_view.arch_db})
action = env.ref("Erronka_estatistikak.action_erronka_estatistikak_dashboard_board").read()[0]
## Context-a pasatzea garrantzitsua da (filter/defektuak gal ez daitezen)
action["context"] = dict(env.context)
        </field>
    </record>

    <record id="action_erronka_estatistikak_open_salmentak" model="ir.actions.server">
        <field name="name">Estatistikak - Salmentak (eguneratu)</field>
        <field name="model_id" ref="model_erronka_estatistika_salmenta" />
        <field name="state">code</field>
        <field name="code">
env["erronka.estatistika.salmenta"]._eguneratu_datuak()
action = env.ref("Erronka_estatistikak.action_erronka_estatistika_salmenta").read()[0]
## Odoo-k batzuetan group by “custom” uzten du; guk hemen ezkutatu nahi dugu
action["hideCustomGroupBy"] = True
## Defektuz egunaren arabera taldekatuta (search view-eko filter name=fecha_dia)
action["context"] = dict(env.context, search_default_fecha_dia=1)
        </field>
    </record>

    <record id="action_erronka_estatistikak_open_produktuak" model="ir.actions.server">
        <field name="name">Estatistikak - Produktuak (eguneratu)</field>
        <field name="model_id" ref="model_erronka_estatistika_produktua" />
        <field name="state">code</field>
        <field name="code">
env["erronka.estatistika.produktua"]._eguneratu_datuak()
action = env.ref("Erronka_estatistikak.action_erronka_estatistika_produktua").read()[0]
action["context"] = dict(env.context)
        </field>
    </record>

    <record id="action_erronka_estatistikak_open_stocka" model="ir.actions.server">
        <field name="name">Estatistikak - Stocka (eguneratu)</field>
        <field name="model_id" ref="model_erronka_estatistika_osagaia_stock" />
        <field name="state">code</field>
        <field name="code">
env["erronka.estatistika.osagaia_stock"]._eguneratu_datuak()
action = env.ref("Erronka_estatistikak.action_erronka_estatistika_osagaia_stock").read()[0]
action["context"] = dict(env.context)
        </field>
    </record>

    <record id="action_erronka_estatistikak_export_pdf" model="ir.actions.server">
        <field name="name">Estatistikak - PDF-a exportatu</field>
        <field name="model_id" ref="model_erronka_estatistika_dashboard" />
        <field name="state">code</field>
        <field name="code">
dashboard = env["erronka.estatistika.dashboard"].create({})
action = env.ref("Erronka_estatistikak.action_report_erronka_estatistikak_pdf").report_action(dashboard)
action["context"] = dict(env.context)
        </field>
    </record>

    <!-- Dashboard-eko grafiko txikiak egiteko action-ak (board view barruan erabiltzen dira) -->
    <record id="action_erronka_estatistika_salmenta_graph_only" model="ir.actions.act_window">
        <field name="name">Salmentak</field>
        <field name="res_model">erronka.estatistika.salmenta</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_erronka_estatistika_salmenta_graph" />
    </record>

    <record id="action_erronka_estatistika_produktua_graph_only" model="ir.actions.act_window">
        <field name="name">Produktuak</field>
        <field name="res_model">erronka.estatistika.produktua</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_erronka_estatistika_produktua_graph" />
    </record>

    <record id="action_erronka_estatistika_osagaia_stock_graph_only" model="ir.actions.act_window">
        <field name="name">Stocka</field>
        <field name="res_model">erronka.estatistika.osagaia_stock</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_erronka_estatistika_osagaia_stock_graph" />
    </record>

    <!-- Board dashboard-a: 3 grafiko txiki batera (Odoo-ko board modulua erabiliz) -->
    <record id="view_erronka_estatistikak_dashboard_board" model="ir.ui.view">
        <field name="name">erronka.estatistikak.dashboard.board</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Estatistikak - Dashboard" class="erronka_estatistikak_dashboard">
                <board style="1-1-1">
                    <column>
                        <action name="%(action_erronka_estatistika_salmenta_graph_only)d"
                            string="Salmentak" view_mode="graph" domain="[]"
                            context="{'search_default_fecha_dia': 1}" />
                    </column>
                    <column>
                        <action name="%(action_erronka_estatistika_produktua_graph_only)d"
                            string="Produktuak" view_mode="graph" domain="[]" context="{}" />
                    </column>
                    <column>
                        <action name="%(action_erronka_estatistika_osagaia_stock_graph_only)d"
                            string="Stocka" view_mode="graph" domain="[]" context="{}" />
                    </column>
                </board>
            </form>
        </field>
    </record>

    <!-- CSS “hack” txiki bat: board-eko headerra ezkutatzeko (garbiago ikusteko) -->
    <template id="erronka_estatistikak_hide_board_layout"
        inherit_id="web.assets_backend_legacy_lazy">
        <xpath expr="." position="inside">
            <style>
                .o-dashboard-header,
                .o_dashboard_header,
                .o_dashboard_header_btns,
                .o_dashboard_header_buttons,
                .o_board_controller .o_dashboard_header,
                .o_control_panel .o_dashboard_header,
                .o_board_controller .o-dashboard-header,
                .o_control_panel .o-dashboard-header {
                    display: none !important;
                }
            </style>
        </xpath>
    </template>

    <!-- Board dashboard-a irekitzeko action normala (server action-etik honetara salto egiten dugu) -->
    <record id="action_erronka_estatistikak_dashboard_board" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_erronka_estatistikak_dashboard_board" />
        <field name="target">current</field>
    </record>

    <record id="action_report_erronka_estatistikak_pdf" model="ir.actions.report">
        <field name="name">Estatistikak (PDF)</field>
        <field name="model">erronka.estatistika.dashboard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">erronka_estatistikak.report_estatistikak_pdf</field>
        <field name="report_file">erronka_estatistikak.report_estatistikak_pdf</field>
        <field name="binding_model_id" ref="model_erronka_estatistika_dashboard" />
        <field name="binding_type">report</field>
        <field name="print_report_name">'Estatistikak - %s' % (object.id)</field>
    </record>

    <!-- Beste dashboard “sinplea”: zenbakiak + botoiak (TransientModel-eko form) -->
    <record id="view_erronka_estatistika_dashboard_form" model="ir.ui.view">
        <field name="name">erronka.estatistika.dashboard.form</field>
        <field name="model">erronka.estatistika.dashboard</field>
        <field name="arch" type="xml">
            <form string="Estatistikak - Dashboard">
                <header>
                    <!-- Hau server action bat da: datuak eguneratu + board berriz kargatu -->
                    <button type="action" name="%(action_erronka_estatistikak_open_dashboard)d"
                        string="Birkargatu" class="oe_highlight" />
                    <button type="action" name="%(action_report_erronka_estatistikak_pdf)d"
                        string="PDF-a exportatu" class="btn-secondary" />
                </header>
                <sheet>
                    <group>
                        <group string="Salmentak (hist.)">
                            <field name="salmenta_totala" />
                            <field name="erreserba_kopurua" />
                            <field name="ticket_batezbestekoa" />
                            <button type="action"
                                name="%(action_erronka_estatistikak_open_salmentak)d"
                                string="Ikusi salmentak" class="btn-secondary" />
                        </group>
                        <group string="Produktuak">
                            <field name="top_produktua" />
                            <field name="top_kantitatea" />
                            <button type="action"
                                name="%(action_erronka_estatistikak_open_produktuak)d"
                                string="Ikusi produktuak" class="btn-secondary" />
                        </group>
                    </group>
                    <group string="Stocka">
                        <field name="stock_gutxi_kopurua" />
                        <button type="action" name="%(action_erronka_estatistikak_open_stocka)d"
                            string="Ikusi stocka" class="btn-secondary" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Dashboard “sinplea” irekitzeko action -->
    <record id="action_erronka_estatistika_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">erronka.estatistika.dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_erronka_estatistika_dashboard_form" />
        <field name="target">current</field>
    </record>

    <!-- Salmentak: tree (lista) + graph (grafikoa) + search (filtroak) -->
    <record id="view_erronka_estatistika_salmenta_tree" model="ir.ui.view">
        <field name="name">erronka.estatistika.salmenta.tree</field>
        <field name="model">erronka.estatistika.salmenta</field>
        <field name="arch" type="xml">
            <tree>
                <header>
                    <button name="action_eguneratu" type="object" string="Eguneratu datuak"
                        class="oe_highlight" />
                    <button name="action_exportar_pdf" type="object" string="PDF-a exportatu"
                        class="btn-secondary" />
                </header>
                <field name="eguna" />
                <field name="salmenta_totala" />
                <field name="erreserba_kopurua" />
                <field name="ticket_batezbestekoa" />
            </tree>
        </field>
    </record>

    <record id="view_erronka_estatistika_salmenta_graph" model="ir.ui.view">
        <field name="name">erronka.estatistika.salmenta.graph</field>
        <field name="model">erronka.estatistika.salmenta</field>
        <field name="arch" type="xml">
            <graph string="Salmentak" type="line">
                <!-- measure = y ardatzean kalkulua. operator="avg" = batezbestekoa -->
                <field name="ticket_batezbestekoa" type="measure" operator="avg" />
            </graph>
        </field>
    </record>

    <record id="view_erronka_estatistika_salmenta_search" model="ir.ui.view">
        <field name="name">erronka.estatistika.salmenta.search</field>
        <field name="model">erronka.estatistika.salmenta</field>
        <field name="arch" type="xml">
            <search string="Salmentak">
                <group expand="0" string="Fecha">
                    <!-- Filter hauek group_by bat jartzen dute, gure computed key-ak erabiliz -->
                    <filter string="Día" name="fecha_dia" context="{'group_by':'eguna_key_day'}" />
                    <filter string="Mes" name="fecha_mes" context="{'group_by':'eguna_key_month'}" />
                    <filter string="Trimestre" name="fecha_trimestre"
                        context="{'group_by':'eguna_key_quarter'}" />
                    <filter string="Año" name="fecha_ano" context="{'group_by':'eguna_key_year'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_erronka_estatistika_salmenta" model="ir.actions.act_window">
        <field name="name">Salmentak</field>
        <field name="res_model">erronka.estatistika.salmenta</field>
        <field name="view_mode">graph,tree</field>
        <field name="view_id" ref="view_erronka_estatistika_salmenta_graph" />
        <field name="search_view_id" ref="view_erronka_estatistika_salmenta_search" />
    </record>

    <!-- Produktuak: tree + graph -->
    <record id="view_erronka_estatistika_produktua_tree" model="ir.ui.view">
        <field name="name">erronka.estatistika.produktua.tree</field>
        <field name="model">erronka.estatistika.produktua</field>
        <field name="arch" type="xml">
            <tree>
                <header>
                    <button name="action_eguneratu" type="object" string="Eguneratu datuak"
                        class="oe_highlight" />
                    <button name="action_exportar_pdf" type="object" string="PDF-a exportatu"
                        class="btn-secondary" />
                </header>
                <field name="eguna" />
                <field name="produktua_izena" />
                <field name="ordainduta" />
                <field name="kantitatea" />
                <field name="diru_totala" />
            </tree>
        </field>
    </record>

    <record id="view_erronka_estatistika_produktua_graph" model="ir.ui.view">
        <field name="name">erronka.estatistika.produktua.graph</field>
        <field name="model">erronka.estatistika.produktua</field>
        <field name="arch" type="xml">
            <graph string="Produktuak" type="bar">
                <!-- Bi neurri: kantitatea eta diru_totala. Row = produktua, Col = eguna -->
                <field name="kantitatea" type="measure" />
                <field name="diru_totala" type="measure" />
                <field name="produktua_izena" type="row" />
                <field name="eguna" type="col" />
            </graph>
        </field>
    </record>

    <record id="action_erronka_estatistika_produktua" model="ir.actions.act_window">
        <field name="name">Produktuak</field>
        <field name="res_model">erronka.estatistika.produktua</field>
        <field name="view_mode">graph,tree</field>
        <field name="view_id" ref="view_erronka_estatistika_produktua_graph" />
    </record>

    <!-- Stocka: tree + graph -->
    <record id="view_erronka_estatistika_osagaia_stock_tree" model="ir.ui.view">
        <field name="name">erronka.estatistika.osagaia_stock.tree</field>
        <field name="model">erronka.estatistika.osagaia_stock</field>
        <field name="arch" type="xml">
            <tree>
                <header>
                    <button name="action_eguneratu" type="object" string="Eguneratu datuak"
                        class="oe_highlight" />
                    <button name="action_exportar_pdf" type="object" string="PDF-a exportatu"
                        class="btn-secondary" />
                </header>
                <field name="osagaia_izena" />
                <field name="stock" />
                <field name="prezioa" />
                <field name="azken_eguneraketa" />
            </tree>
        </field>
    </record>

    <record id="view_erronka_estatistika_osagaia_stock_graph" model="ir.ui.view">
        <field name="name">erronka.estatistika.osagaia_stock.graph</field>
        <field name="model">erronka.estatistika.osagaia_stock</field>
        <field name="arch" type="xml">
            <graph string="Stocka" type="bar">
                <!-- Stock kopurua “measure” bezala eta osagaia “row” bezala -->
                <field name="stock" type="measure" />
                <field name="osagaia_izena" type="row" />
            </graph>
        </field>
    </record>

    <record id="action_erronka_estatistika_osagaia_stock" model="ir.actions.act_window">
        <field name="name">Stocka</field>
        <field name="res_model">erronka.estatistika.osagaia_stock</field>
        <field name="view_mode">graph,tree</field>
        <field name="view_id" ref="view_erronka_estatistika_osagaia_stock_graph" />
    </record>

    <!-- Wizard: PDF dena exportatu baino lehen ohartarazpena erakutsi -->
    <record id="view_exportar_pdf_baiezdatzea_wizard_form" model="ir.ui.view">
        <field name="name">erronka.exportar.pdf.baiezdatzea.wizard.form</field>
        <field name="model">erronka.exportar.pdf.baiezdatzea.wizard</field>
        <field name="arch" type="xml">
            <form string="PDF-a exportatu">
                <group>
                    <div class="alert alert-warning" role="alert">
                        <strong>Kontuz:</strong> PDF honek hiru atal guztietako informazioa biltzen du:
                        <strong>Salmentak</strong>, <strong>Produktuak</strong> eta <strong>Stocka</strong>.<br/><br/>
                        Atal zehatz baten informazioa soilik exportatu nahi baduzu, joan atal horretara
                        eta bertako <em>"PDF-a exportatu"</em> botoia erabili.
                    </div>
                </group>
                <footer>
                    <button name="action_exportar_dena" type="object" string="Bai, dena exportatu"
                        class="btn-primary" />
                    <button string="Utzi" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_exportar_pdf_baiezdatzea_wizard" model="ir.actions.act_window">
        <field name="name">PDF-a exportatu</field>
        <field name="res_model">erronka.exportar.pdf.baiezdatzea.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_exportar_pdf_baiezdatzea_wizard_form" />
        <field name="target">new</field>
    </record>

    <!-- Wizard = popup txiki bat: dena batera eguneratzeko botoiarekin -->
    <record id="view_erronka_estatistika_eguneratu_wizard_form" model="ir.ui.view">
        <field name="name">erronka.estatistika.eguneratu.wizard.form</field>
        <field name="model">erronka.estatistika.eguneratu.wizard</field>
        <field name="arch" type="xml">
            <form string="Estatistikak eguneratu">
                <group>
                    <!-- Testu laburra erabiltzaileari: zer egingo duen botoiak -->
                    <div class="o_form_label">Egin klik 'Eguneratu' botoian API-tik datuak berriz
                        kalkulatzeko.</div>
                </group>
                <footer>
                    <!-- Popup-eko botoia: Python metodoa deitu -->
                    <button name="action_eguneratu_dena" type="object" string="Eguneratu"
                        class="btn-primary" />
                    <button string="Utzi" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard-a irekitzeko action (menuan “Eguneratu” sakatzean) -->
    <record id="action_erronka_estatistika_eguneratu_wizard" model="ir.actions.act_window">
        <field name="name">Estatistikak eguneratu</field>
        <field name="res_model">erronka.estatistika.eguneratu.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_erronka_estatistika_eguneratu_wizard_form" />
        <field name="target">new</field>
    </record>

    <record id="view_report_estatistikak_pdf" model="ir.ui.view">
        <field name="name">erronka_estatistikak.report_estatistikak_pdf</field>
        <field name="type">qweb</field>
        <field name="key">erronka_estatistikak.report_estatistikak_pdf</field>
        <field name="arch" type="xml">
            <t t-name="erronka_estatistikak.report_estatistikak_pdf">
                <t t-call="web.html_container">
                    <t t-call="web.external_layout">
                        <t t-set="doc" t-value="docs and docs[0] or False" />
                        <div class="page">
                            <h2>Erronka Estatistikak</h2>
                            <p>
                                <strong>Data:</strong>
                                <t t-esc="report_date_str" />
                            </p>

                            <h3>Salmentak</h3>
                            <div t-raw="sales_chart_svg" />
                            <table class="table table-sm o_main_table" style="width: 100%; margin-top: 8px;">
                                <thead>
                                    <tr>
                                        <th>Eguna</th>
                                        <th style="text-align:right;">Salmenta totala</th>
                                        <th style="text-align:right;">Erreserbak</th>
                                        <th style="text-align:right;">Ticket (avg)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="sales_rows" t-as="r">
                                        <tr>
                                            <td><t t-esc="r['eguna']" /></td>
                                            <td style="text-align:right;"><t t-esc="r['salmenta_totala']" /></td>
                                            <td style="text-align:right;"><t t-esc="r['erreserba_kopurua']" /></td>
                                            <td style="text-align:right;"><t t-esc="r['ticket_batezbestekoa']" /></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>

                            <h3 style="margin-top: 18px;">Produktuak (ordainduta)</h3>
                            <div t-raw="products_chart_svg" />
                            <table class="table table-sm o_main_table" style="width: 100%; margin-top: 8px;">
                                <thead>
                                    <tr>
                                        <th>Produktua</th>
                                        <th style="text-align:right;">Kantitatea</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="product_rows" t-as="p">
                                        <tr>
                                            <td><t t-esc="p['produktua']" /></td>
                                            <td style="text-align:right;"><t t-esc="p['kantitatea']" /></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>

                            <h3 style="margin-top: 18px;">Stocka</h3>
                            <div t-raw="stock_chart_svg" />
                            <table class="table table-sm o_main_table" style="width: 100%; margin-top: 8px;">
                                <thead>
                                    <tr>
                                        <th>Osagaia</th>
                                        <th style="text-align:right;">Stock</th>
                                        <th style="text-align:right;">Prezioa</th>
                                        <th>Azken eguneraketa</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="stock_rows[:50]" t-as="s">
                                        <tr>
                                            <td><t t-esc="s['osagaia']" /></td>
